{
  "expo": {
    "name": "Mystic",
    "slug": "mystic-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07050F"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mysticapp.ai",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Mystic benötigt dein Mikrofon für das Gespräch mit deiner Beraterin.",
        "NSCameraUsageDescription": "Mystic benötigt deine Kamera für Kaffeesatz- und Palmreading.",
        "NSPhotoLibraryUsageDescription": "Mystic benötigt Zugriff auf deine Fotos für Kaffeesatz- und Palmreading."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07050F"
      },
      "package": "com.mysticapp.ai",
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Mystic benötigt deine Kamera für Kaffeesatz- und Palmreading."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "mystic",
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
